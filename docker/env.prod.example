# =====================================================
# Nexora 站点 - 生产环境变量
# 复制为 .env 并修改所有 CHANGE_ME：
#   cp docker/env.prod.example .env
#   php artisan key:generate   （或 echo "base64:$(openssl rand -base64 32)"）
# =====================================================

# CI/CD 镜像（手动构建推送后填写；本地构建可忽略，用默认值）
# 格式：ghcr.io/<owner>/<repo>-app:latest  /  -web:latest（均小写）
REGISTRY_IMAGE_APP=nexora-app:latest
REGISTRY_IMAGE_WEB=nexora-web:latest

APP_NAME=Nexora
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_PORT=80

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ---------- 数据库（容器内 mysql）----------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nexora
DB_USERNAME=nexora
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password

# ---------- 会话 / 缓存 / 队列（无 Redis，用数据库 / 同步）----------
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=sync

# ---------- 邮件（联系表单通知）----------
# 不填 CONTACT_NOTIFY_EMAIL 则只入库、不发通知
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=hello@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_NOTIFY_EMAIL=

# 容器启动时是否自动跑迁移（默认 false，建议人工执行 migrate）
AUTO_MIGRATE=false
